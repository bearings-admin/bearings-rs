# Bearings reverse proxy (Caddy) — canonical copy of /etc/caddy/Caddyfile on the VPS.
# NOT auto-applied by deploy.sh: after editing, copy to /etc/caddy/Caddyfile on the
# VPS and `systemctl reload caddy`. Kept in the repo so infra is reviewable, not just
# a comment in main.rs.
#
# `header_up X-Forwarded-For {remote_host}` OVERWRITES any client-sent X-Forwarded-For
# with the real peer IP. Without this, a client can spoof XFF and the app's per-IP rate
# limiter (tower_governor SmartIpKeyExtractor, see bearings-backend/src/main.rs) reads
# the spoofed value, so rotating it per request defeats the limit. Caddy is the only
# edge proxy, so overwriting (not appending) is correct here.
srv1744879.hstgr.cloud {
	reverse_proxy localhost:3000 {
		header_up X-Forwarded-For {remote_host}
	}
}
