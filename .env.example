# Bearings backend — copy to .env and fill in. These are the only vars the
# code reads (see config.rs and bearings-agent). The backend fails fast at
# startup if a required Supabase var is missing.

# Supabase — the only datastore (PostgREST over HTTPS; no local DB needed)
SUPABASE_URL=https://mntdhflffhrjjvipxgyl.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Admin — token that gates /?zone=admin (feed/candidate review)
ADMIN_TOKEN=your_admin_token_here

# Server
PORT=3000
HOST=0.0.0.0
RUST_LOG=bearings_backend=info
